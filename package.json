{
  "name": "medlink",
  "private": true,
  "description": "Hooks Git partagés du monorepo MedLink (voir ML-102)",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "frontend-web/**/*.{js,jsx,ts,tsx}": [
      "frontend-web/node_modules/.bin/oxlint --fix --config=frontend-web/.oxlintrc.json",
      "frontend-web/node_modules/.bin/prettier --write"
    ],
    "frontend-web/**/*.{css,json}": [
      "frontend-web/node_modules/.bin/prettier --write"
    ],
    "frontend-mobile/**/*.{js,jsx,ts,tsx}": [
      "frontend-mobile/node_modules/.bin/eslint --fix --config=frontend-mobile/eslint.config.js",
      "frontend-mobile/node_modules/.bin/prettier --write"
    ],
    "frontend-mobile/**/*.{css,json}": [
      "frontend-mobile/node_modules/.bin/prettier --write"
    ],
    "backend/**/*.php": [
      "backend/vendor/bin/php-cs-fixer fix --config=backend/.php-cs-fixer.dist.php --cache-file=backend/.php-cs-fixer.cache"
    ]
  }
}
