# Docker Compose — ports exposés sur l'hôte
APP_PORT=8080
POSTGRES_PORT=5432
WEB_PORT=5173

# PostgreSQL
POSTGRES_DB=medlink
POSTGRES_USER=medlink
POSTGRES_PASSWORD=changeme

# Frontend mobile (Expo) — IP LAN de cette machine, pour que le téléphone
# (Expo Go) puisse joindre le bundler Metro et l'API depuis le même wifi.
# "localhost" ne fonctionne pas ici : ce n'est ni le conteneur ni le
# téléphone. Trouver son IP LAN : `hostname -I | awk '{print $1}'` (Linux).
# Le service "mobile" du docker-compose.yml utilise `network_mode: host`
# (Linux uniquement).
HOST_LAN_IP=192.168.1.42
