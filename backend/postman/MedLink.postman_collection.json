            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          }
        },
        {
          "name": "POST - 422 note trop longue (>1000 car.)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 422', () => pm.response.to.have.status(422));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{patient_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patient_id}},\n  \"mood\": 3,\n  \"painLevel\": 4,\n  \"bloodPressure\": \"120/80\",\n  \"note\": \"{{$randomLoremParagraphs}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          },
          "description": "Remplace la valeur de 'note' par une chaine de plus de 1000 caracteres (ex: colle 1001 fois la lettre 'a') si {{$randomLoremParagraphs}} ne suffit pas."
        },
        {
          "name": "POST - 403 aidant non rattache",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 403', () => pm.response.to.have.status(403));"] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{aidant_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patient_id}},\n  \"mood\": 3,\n  \"painLevel\": 4,\n  \"bloodPressure\": \"120/80\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          },
          "description": "A executer AVANT d'avoir cree la relation PatientAidant en base (voir description du dossier)."
        },
        {
          "name": "POST - 201 aidant rattache (saisie par aidant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('marquee saisie par aidant', () => pm.expect(json.enteredByCaregiver).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{aidant_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patient_id}},\n  \"mood\": 3,\n  \"painLevel\": 4,\n  \"bloodPressure\": \"120/80\",\n  \"note\": \"Saisie par aidant\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          },
          "description": "A executer APRES avoir insere la relation PatientAidant active=true en base."
        },
        {
          "name": "GET - Liste (patient, voit ses propres entrees)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patient_token}}" }],
            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          }
        },
