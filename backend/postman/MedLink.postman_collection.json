            },
            "url": { "raw": "{{base_url}}/api/journal_entries", "host": ["{{base_url}}"], "path": ["api", "journal_entries"] }
          }
        },
        {
          "name": "GET - Une entree par id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patient_token}}" }],
            "url": {
