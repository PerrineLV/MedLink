# Symfony
APP_ENV=dev
APP_SECRET=changeme
TRUSTED_PROXIES=
TRUSTED_HOSTS=

# Base de données (doit correspondre aux identifiants du docker-compose.yml racine)
DATABASE_URL="postgresql://medlink:changeme@db:5432/medlink?serverVersion=16&charset=utf8"

# JWT (lexik/jwt-authentication-bundle, RS256)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme

# CORS (front web + mobile en local)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Monitoring
SENTRY_DSN=
